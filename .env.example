# ============================================
# Security Playbooks Environment Configuration
# ============================================

# --- General ---
ENV=development
LOG_LEVEL=info

# --- SIEM / Logging ---
SIEM_URL=http://localhost:9200
SIEM_API_KEY=your_api_key_here

# --- Threat Intelligence ---
VT_API_KEY=your_virustotal_api_key_here
MISP_URL=http://localhost:8080
MISP_API_KEY=your_misp_api_key_here

# --- Database (optional) ---
DATABASE_URL=postgresql://user:password@localhost:5432/security_db

# --- Paths ---
LOG_PATH=./logs
DATA_PATH=./data

# 🔴 IMPORTANT:
# Do NOT put real secrets here
# Copy this file to `.env` and fill real values
